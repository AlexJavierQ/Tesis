# Copia este archivo como  secrets.toml  y pon tus keys.
#   En Windows:  copy .streamlit\secrets.toml.example .streamlit\secrets.toml
# El secrets.toml real NO se sube a GitHub (esta en .gitignore).

# Proveedor de LLM activo: "groq" (14.400 req/dia gratis) o "gemini"
LLM_PROVIDER = "groq"

# Groq / Llama  -> key gratis (sin tarjeta) en https://console.groq.com/keys
GROQ_API_KEY = "gsk_TU_KEY_AQUI"

# Gemini (alternativa) -> key real en https://aistudio.google.com/  (empieza con AIza)
GEMINI_API_KEY = "AIza_TU_KEY_AQUI"
